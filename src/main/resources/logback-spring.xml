<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 로그 파일 저장 위치입니다. IDE 콘솔과 파일 로그가 같은 패턴을 쓰도록 아래 LOG_PATTERN을 공유합니다. -->
    <property name="LOG_PATH" value="logs"/>
    <!-- requestId는 RequestLoggingInterceptor가 MDC에 넣습니다. 같은 요청의 앞뒤 로그를 추적할 때 사용합니다. -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level ${PID:-} --- [%thread] [%X{requestId:-no-request}] %logger{36} : %msg%n"/>

    <!-- IDE/터미널 콘솔 출력입니다. 파일 로그와 같은 패턴/인코딩을 유지합니다. -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 전체 애플리케이션 로그입니다. 운영 중 요청, 서비스 AOP, 작업 로그를 모두 확인합니다. -->
    <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/ssafyhome.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/ssafyhome.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>14</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ERROR 이상만 별도 저장합니다. 장애 원인 추적 시 ssafyhome.log보다 먼저 확인하기 좋습니다. -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/ssafyhome-error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/ssafyhome-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 프로젝트 패키지는 INFO부터 남깁니다. DEBUG로 낮추면 외부 API/DB 조회 로그가 급격히 많아집니다. -->
    <logger name="com.ssafy.home" level="INFO"/>

    <!-- 콘솔, 일반 파일, 에러 파일을 동시에 사용합니다. -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>
</configuration>
